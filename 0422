import requests
from bs4 import BeautifulSoup

def get_exchange_rate(code):
    url = f"https://finance.naver.com/marketindex/exchangeDetail.nhn?marketindexCd=FX_{code}KRW"
    response = requests.get(url)
    soup = BeautifulSoup(response.content, 'html.parser')
    
    # 현재 환율 데이터 추출
    rate = soup.find('p', class_='no_today').find('em', class_='no_up').text
    print(f"현재 1 {code} 당 환율은 {rate}원입니다.")

if __name__ == "__main__":
    # USD(달러), JPY(엔화), EUR(유로) 등 입력 가능
    get_exchange_rate("USD")
